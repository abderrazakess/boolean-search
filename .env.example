# ============================================================================
# .env.example - Environment variables template for Railway deployment
# ============================================================================
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============================================================================
# REQUIRED - Application Core
# ============================================================================

# Node environment (Railway will set this automatically to 'production')
NODE_ENV=production

# Server port (Railway will set this automatically, but default is 3000)
PORT=3000


# ============================================================================
# REQUIRED - Database (MySQL from Railway)
# ============================================================================

# MySQL connection string from Railway
# Format: mysql://user:password@host:port/database
# Railway provides this automatically when you create a MySQL database
# Example: mysql://root:password123@containers-us-west-123.railway.app:1234/railway
DATABASE_URL=


# ============================================================================
# REQUIRED - AI Provider (OpenAI)
# ============================================================================

# OpenAI API Configuration
# For direct OpenAI usage:
BUILT_IN_FORGE_API_URL=https://api.openai.com/v1
BUILT_IN_FORGE_API_KEY=sk-your-openai-api-key-here

# Note: The application uses OpenAI for:
# - AI chat functionality (/api/chat)
# - Boolean search query generation
# - Keyword grouping and analysis


# ============================================================================
# REQUIRED - Security
# ============================================================================

# JWT Secret for session cookies (generate a strong random string)
# Generate with: openssl rand -base64 32
# Or online: https://generate-secret.vercel.app/32
JWT_SECRET=


# ============================================================================
# OPTIONAL - OAuth Authentication (Manus Platform)
# ============================================================================

# If you're using Manus OAuth for user authentication
# Leave empty if not using OAuth features
VITE_APP_ID=
OAUTH_SERVER_URL=https://oauth.manus.im
OWNER_OPEN_ID=


# ============================================================================
# OPTIONAL - News API (GNews)
# ============================================================================

# GNews API key for fetching HR/industry news
# Get one at: https://gnews.io/
# Leave empty if you don't need the news feature
GNEWS_API_KEY=


# ============================================================================
# RAILWAY DEPLOYMENT NOTES
# ============================================================================
#
# 1. Create MySQL Database in Railway:
#    - Go to Railway Dashboard
#    - Click "New" → "Database" → "MySQL"
#    - Copy the DATABASE_URL connection string
#
# 2. Set Environment Variables in Railway:
#    - Go to your service → "Variables" tab
#    - Add all REQUIRED variables above
#    - Railway will auto-set NODE_ENV and PORT
#
# 3. Build & Start Commands (auto-detected):
#    - Build: pnpm install && pnpm run build
#    - Start: node dist/index.js
#
# 4. Run Database Migrations:
#    - After first deployment, go to Railway service
#    - Click "Settings" → "Deploy" 
#    - Or use Railway CLI: railway run pnpm run db:push
#
# 5. Domain Setup:
#    - Railway provides a subdomain: yourapp.up.railway.app
#    - Add custom domain in "Settings" → "Domains"
#
# ============================================================================
